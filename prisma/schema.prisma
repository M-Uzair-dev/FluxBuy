// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



enum tokenType {
  REFRESH_TOKEN
  RESET_TOKEN
  VERIFICATION_TOKEN
}

enum orderStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique()
  pfp String?
  bio String? 
  password String?
  googleId String? @unique()
  emailVerified Boolean @default(false)

  tokens Token[]
  products Product[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model Token {
  id String @id() @default(uuid())
  tokenHash String
  expiresAt DateTime
  type tokenType

  userId String
  user User @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model Product {
  id String @id() @default(uuid())
  name String
  imageUrl String?
  description String?
  price Int
  quantity Int
  dropTime DateTime

  userId String
  user User @relation(references: [id], fields: [userId])

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model Order {
  id String @id() @default(uuid())
  quantity Int
  totalAmount Int
  status orderStatus @default(PENDING)
  

  productId String
  product Product @relation(references: [id], fields: [productId])

  userId String
  user User @relation(references: [id], fields: [userId])
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}